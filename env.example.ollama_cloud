# Ollama Cloud example environment variables
# Copy this file to .env.ollama_cloud and fill values before running tests.

# Your Ollama Cloud API key (do NOT commit your real key)
OLLAMA_API_KEY=REPLACE_ME

# Ollama Cloud host (default provided by Ollama Cloud docs)
OLLAMA_CLOUD_HOST=https://cloud.ollama.com

# Optional: model name to use from Ollama Cloud (e.g., `llama3`, `mistral`)
OLLAMA_CLOUD_MODEL=llama3

# Example: export these before running scripts
# source .env.ollama_cloud
